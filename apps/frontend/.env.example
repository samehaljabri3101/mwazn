# ── Public (baked into client bundle at build time) ───────────────────────────
# Browser-side API URL. Must be reachable from the user's browser.
# For Docker Compose local dev: http://localhost:3001/api
# For production: https://api.yourdomain.com/api
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ── Server-side only (SSR / Next.js server components) ───────────────────────
# Used by server-side rendering to reach the backend inside the Docker network.
# NOT exposed to the browser. For Docker Compose: http://backend:3001/api
# For production: http://backend-internal-hostname:3001/api  (or same as above if no Docker)
API_INTERNAL_URL=http://localhost:3001/api
