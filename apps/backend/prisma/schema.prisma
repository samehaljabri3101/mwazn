generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  BUYER_ADMIN
  SUPPLIER_ADMIN
  PLATFORM_ADMIN
  FREELANCER
  CUSTOMER
}

enum CompanyType {
  BUYER
  SUPPLIER
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum SubscriptionPlan {
  FREE
  PRO
}

enum ListingStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum RFQStatus {
  OPEN
  CLOSED
  AWARDED
  CANCELLED
}

enum QuoteStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum DealStatus {
  AWARDED
  IN_PROGRESS
  DELIVERED
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum DocumentType {
  CR
  VAT
  LICENSE
  ISO
  OTHER
  NATIONAL_ID
  IQAMA
  BUSINESS_PLATFORM
  MAROOF
}

enum ModerationStatus {
  ACTIVE
  FLAGGED
  REMOVED
  REJECTED
}

enum ModerationSource {
  SYSTEM
  ADMIN
}

enum AppealTargetType {
  RFQ
  LISTING
}

enum AppealStatus {
  OPEN
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  CLOSED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  avatarUrl    String?
  role         Role
  isActive     Boolean  @default(true)

  company   Company @relation(fields: [companyId], references: [id])
  companyId String

  refreshTokens       RefreshToken[]
  sentMessages        Message[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  appealsAsAppellant  ModerationAppeal[] @relation("AppealAppellant")
  appealsAsReviewer   ModerationAppeal[] @relation("AppealReviewer")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([companyId])
}

model Company {
  id                  String             @id @default(cuid())
  nameAr              String
  nameEn              String
  crNumber            String?            @unique
  slug                String?            @unique
  type                CompanyType
  verificationStatus  VerificationStatus @default(PENDING)
  city                String?
  phone               String?
  website             String?
  logoUrl             String?
  coverImageUrl       String?
  descriptionAr       String?            @db.Text
  descriptionEn       String?            @db.Text
  plan                SubscriptionPlan   @default(FREE)
  planExpiresAt       DateTime?
  quotesUsedThisMonth Int                @default(0)
  quotaResetAt        DateTime?
  isActive            Boolean            @default(true)

  // ── Legal & compliance ─────────────────────────────────────────────────────
  vatNumber           String?
  crExpiryDate        DateTime?
  legalForm           String?            // LLC|ESTABLISHMENT|CORPORATION|PARTNERSHIP|JOINT_STOCK
  establishmentYear   Int?
  companySizeRange    String?            // 1-10|11-50|51-200|201-500|500+
  sectors             String[]

  // ── Contact ────────────────────────────────────────────────────────────────
  contactJobTitle     String?

  // ── Supplier profile extras ────────────────────────────────────────────────
  keyClients          String[]
  regionsServed       String[]
  paymentTermsAccepted String[]
  productionCapacity  String?
  isoUrl              String?
  chamberCertUrl      String?
  taxCertUrl          String?

  // ── Identity ───────────────────────────────────────────────────────────────
  isFreelancer                        Boolean   @default(false)
  governmentId                        String?   // National ID or Iqama — private, never public
  governmentIdType                    String?   // "NATIONAL_ID" | "IQAMA"
  businessPlatformVerificationNumber  String?   // Saudi Business Platform No. (FREELANCER)
  maroofNumber                        String?   // Maroof legacy/fallback (FREELANCER, optional)
  verificationSource                  String?   // "CR" | "BUSINESS_PLATFORM" | "MAROOF" | "MANUAL"

  // ── Admin ──────────────────────────────────────────────────────────────────
  adminNotes          String?            @db.Text

  // ── Verification ───────────────────────────────────────────────────────────
  verificationNotes   String?            @db.Text
  verifiedAt          DateTime?
  verifiedBy          String?

  // ── Scoring ────────────────────────────────────────────────────────────────
  supplierScore       Float?         // 0-100 composite platform score
  avgRating           Float?         // 1-5 customer rating average
  scoreUpdatedAt      DateTime?

  // ── Commerce Integration ────────────────────────────────────────────────────
  hasExternalStore      Boolean   @default(false)
  externalStorePlatform String?   // "ZID" | "SALLA" | "OTHER"
  externalStoreUrl      String?
  externalStoreName     String?
  allowDirectOrder      Boolean   @default(false)

  users              User[]
  listings           Listing[]
  rfqs               RFQ[]
  quotesSubmitted    Quote[]
  dealsAsBuyer       Deal[]         @relation("BuyerDeals")
  dealsAsSupplier    Deal[]         @relation("SupplierDeals")
  ratingsGiven       Rating[]       @relation("RaterCompany")
  ratingsReceived    Rating[]       @relation("RatedCompany")
  conversations      Conversation[] @relation("CompanyConversations")
  categories         Category[]     @relation("CompanyCategories")
  receivedInvites    RFQInvite[]    @relation("InvitedSupplier")
  invoices           Invoice[]
  verificationDocs   CompanyVerificationDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([verificationStatus])
  @@index([crNumber])
  @@index([slug])
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Category {
  id        String  @id @default(cuid())
  nameAr    String
  nameEn    String
  slug      String  @unique
  iconUrl   String?
  parentId  String?

  parent   Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children Category[] @relation("CategoryChildren")
  companies Company[] @relation("CompanyCategories")
  listings  Listing[]
  rfqs      RFQ[]

  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([slug])
}

model Listing {
  id            String        @id @default(cuid())
  slug          String?       @unique
  titleAr       String
  titleEn       String
  descriptionAr String?       @db.Text
  descriptionEn String?       @db.Text
  sku           String?
  price         Decimal?      @db.Decimal(12, 2)
  priceTo       Decimal?      @db.Decimal(12, 2)
  currency      String        @default("SAR")
  unit          String?
  minOrderQty   Int?
  leadTimeDays  Int?
  tags          String[]
  certifications String[]
  specsJson     Json?
  requestQuoteOnly Boolean   @default(false)
  vatPercent    Float?
  stockAvailability String   @default("IN_STOCK")  // IN_STOCK|OUT_OF_STOCK|LIMITED
  status        ListingStatus @default(ACTIVE)
  viewCount     Int           @default(0)

  // ── Moderation ─────────────────────────────────────────────────────────────
  moderationStatus  ModerationStatus  @default(ACTIVE)
  moderationReason  String?
  moderatedById     String?
  moderatedAt       DateTime?
  moderationSource  ModerationSource?

  supplier   Company  @relation(fields: [supplierId], references: [id])
  supplierId String

  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String

  images ListingImage[]
  quotes Quote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supplierId])
  @@index([categoryId])
  @@index([status])
  @@index([slug])
  @@index([moderationStatus])
}

model ListingImage {
  id        String  @id @default(cuid())
  url       String
  filename  String  @default("")
  alt       String?
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String

  @@index([listingId])
}

model RFQ {
  id          String    @id @default(cuid())
  title       String
  description String    @db.Text
  projectType String?   // PRODUCT|SERVICE|MANUFACTURING|CONSULTANCY
  quantity    Int?
  unit        String?
  budget      Decimal?  @db.Decimal(12, 2)
  budgetMin   Decimal?  @db.Decimal(12, 2)
  budgetMax   Decimal?  @db.Decimal(12, 2)
  budgetUndisclosed Boolean @default(false)
  currency    String    @default("SAR")
  vatIncluded Boolean   @default(false)
  deadline    DateTime?
  expectedStartDate DateTime?
  locationRequirement String?
  siteVisitRequired Boolean @default(false)
  ndaRequired       Boolean @default(false)
  requiredCertifications String[]
  visibility  String    @default("PUBLIC")  // PUBLIC|INVITE_ONLY
  allowPartialBids Boolean @default(true)
  status      RFQStatus @default(OPEN)

  // ── Moderation ─────────────────────────────────────────────────────────────
  moderationStatus  ModerationStatus  @default(ACTIVE)
  moderationReason  String?
  moderatedById     String?
  moderatedAt       DateTime?
  moderationSource  ModerationSource?

  buyer      Company @relation(fields: [buyerId], references: [id])
  buyerId    String

  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String

  quotes      Quote[]
  attachments FileUpload[]
  images      RfqImage[]
  invites     RFQInvite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buyerId])
  @@index([categoryId])
  @@index([status])
  @@index([moderationStatus])
}

model RfqImage {
  id        String  @id @default(cuid())
  url       String
  filename  String
  mimeType  String
  size      Int
  sortOrder Int     @default(0)

  rfq   RFQ    @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  rfqId String

  uploadedBy   String?
  createdAt DateTime @default(now())

  @@index([rfqId])
}

model Quote {
  id                 String      @id @default(cuid())
  price              Decimal     @db.Decimal(12, 2)
  currency           String      @default("SAR")
  deliveryDays       Int?
  notes              String?     @db.Text
  status             QuoteStatus @default(PENDING)
  validUntil         DateTime?
  vatPercent         Float?
  paymentTerms       String?
  warrantyMonths     Int?
  afterSalesSupport  String?     @db.Text
  technicalProposal  String?     @db.Text
  lineItems          Json?

  rfq        RFQ     @relation(fields: [rfqId], references: [id])
  rfqId      String

  supplier   Company  @relation(fields: [supplierId], references: [id])
  supplierId String

  listing   Listing? @relation(fields: [listingId], references: [id])
  listingId String?

  deal        Deal?
  attachments FileUpload[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rfqId])
  @@index([supplierId])
  @@index([status])
}

model Deal {
  id          String     @id @default(cuid())
  status      DealStatus @default(AWARDED)
  totalAmount Decimal    @db.Decimal(12, 2)
  currency    String     @default("SAR")
  notes       String?    @db.Text

  // Fulfillment / shipping
  trackingNumber String?
  carrierName    String?
  shippedAt      DateTime?
  deliveredAt    DateTime?

  quote    Quote   @relation(fields: [quoteId], references: [id])
  quoteId  String  @unique

  buyer      Company @relation("BuyerDeals", fields: [buyerId], references: [id])
  buyerId    String

  supplier   Company @relation("SupplierDeals", fields: [supplierId], references: [id])
  supplierId String

  ratings Rating[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buyerId])
  @@index([supplierId])
  @@index([status])
}

model Rating {
  id         String  @id @default(cuid())
  score      Int
  comment    String? @db.Text
  isDisputed Boolean @default(false)
  disputedAt DateTime?

  deal   Deal   @relation(fields: [dealId], references: [id])
  dealId String

  rater   Company @relation("RaterCompany", fields: [raterId], references: [id])
  raterId String

  rated   Company @relation("RatedCompany", fields: [ratedId], references: [id])
  ratedId String

  createdAt DateTime @default(now())

  @@unique([dealId, raterId])
  @@index([ratedId])
  @@index([raterId])
}

model Conversation {
  id      String  @id @default(cuid())
  subject String?
  rfqId   String?

  participants Company[] @relation("CompanyConversations")
  messages     Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id          String  @id @default(cuid())
  body        String  @db.Text
  isRead      Boolean @default(false)
  messageType String  @default("GENERAL")  // GENERAL|CLARIFICATION|NEGOTIATION|TECHNICAL|COMMERCIAL
  priority    String  @default("NORMAL")   // NORMAL|URGENT

  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String

  sender   User   @relation(fields: [senderId], references: [id])
  senderId String

  attachments FileUpload[]

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([senderId])
}

model FileUpload {
  id           String @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String

  rfq       RFQ?     @relation(fields: [rfqId], references: [id])
  rfqId     String?

  quote     Quote?   @relation(fields: [quoteId], references: [id])
  quoteId   String?

  message   Message? @relation(fields: [messageId], references: [id])
  messageId String?

  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // QUOTE_RECEIVED|QUOTE_ACCEPTED|DEAL_STATUS|MESSAGE|VERIFICATION|INVITE
  titleAr   String
  titleEn   String
  bodyAr    String
  bodyEn    String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

model RFQInvite {
  id         String   @id @default(cuid())
  rfqId      String
  rfq        RFQ      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  supplierId String
  supplier   Company  @relation("InvitedSupplier", fields: [supplierId], references: [id])
  invitedBy  String
  sentAt     DateTime @default(now())

  @@unique([rfqId, supplierId])
}

model AuditLog {
  id        String  @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  ipAddress String?
  userAgent String?
  requestId String?

  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ─── Billing ──────────────────────────────────────────────────────────────────

model Invoice {
  id        String        @id @default(cuid())
  companyId String
  company   Company       @relation(fields: [companyId], references: [id])
  plan      String        @default("PRO")
  amount    Decimal       @db.Decimal(12, 2)
  currency  String        @default("SAR")
  status    InvoiceStatus @default(PENDING)
  provider  String        @default("manual") // stripe|moyasar|manual
  reference String?

  createdAt DateTime  @default(now())
  paidAt    DateTime?

  @@index([companyId])
  @@index([status])
}

// ─── Supplier Verification Documents ─────────────────────────────────────────

model CompanyVerificationDocument {
  id         String      @id @default(cuid())
  companyId  String
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type       DocumentType
  fileUrl    String
  uploadedAt DateTime    @default(now())
  reviewedAt DateTime?
  reviewerId String?
  decision   String?     // APPROVED|REJECTED
  notes      String?     @db.Text

  @@index([companyId])
  @@index([decision])
}

// ─── Moderation Appeals ───────────────────────────────────────────────────────

model ModerationAppeal {
  id                       String            @id @default(cuid())
  targetType               AppealTargetType
  targetId                 String
  appellantUserId          String
  appellantCompanyId       String
  appealStatus             AppealStatus      @default(OPEN)
  originalModerationStatus ModerationStatus
  reason                   String            @db.Text
  adminResponse            String?           @db.Text
  reviewedById             String?
  reviewedAt               DateTime?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  appellantUser  User  @relation("AppealAppellant", fields: [appellantUserId], references: [id])
  reviewedBy     User? @relation("AppealReviewer",  fields: [reviewedById],  references: [id])

  @@index([appellantUserId])
  @@index([targetType, targetId])
  @@index([appealStatus])
}

// ─── Analytics Events ─────────────────────────────────────────────────────────

model AnalyticsEvent {
  id        String   @id @default(cuid())
  event     String   // PAGE_VIEW|RFQ_CREATED|QUOTE_SUBMITTED|QUOTE_ACCEPTED|DEAL_COMPLETED|RATING_POSTED|LISTING_VIEWED
  companyId String?
  userId    String?
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([event])
  @@index([companyId])
  @@index([createdAt])
}
