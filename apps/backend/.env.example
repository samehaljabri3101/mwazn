# ── Database (REQUIRED) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://mwazn:mwazn@localhost:5432/mwazn

# ── Redis (optional — falls back to in-memory cache if not set) ───────────────
REDIS_URL=redis://localhost:6379

# ── JWT (REQUIRED — use strong random values in production) ──────────────────
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me          # ⚠️ MUST be changed before production
JWT_REFRESH_SECRET=change-me-refresh # ⚠️ MUST be changed before production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# REQUIRED in production — used for email callback links and CORS
FRONTEND_URL=http://localhost:3000

# ── Email (optional — set EMAIL_MODE=smtp to enable real delivery) ───────────
# If not set, emails are logged to console (dev mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@mwazn.sa

# ── Payments (optional — Stripe integration stub) ────────────────────────────
# Required to enable real PRO subscription checkout and webhook processing.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# ── Seed / Demo credentials ──────────────────────────────────────────────────
# These are used by prisma/seed.ts to create demo accounts.
# ⚠️ Change ALL of these before any production deployment.
# The seed script is idempotent — it skips if companies already exist.
SEED_ADMIN_EMAIL=admin@mwazn.sa
SEED_ADMIN_PASSWORD=Admin@1234
SEED_SUP_PASSWORD=Supplier@1234
SEED_BUY_PASSWORD=Buyer@1234
