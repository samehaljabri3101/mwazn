# ─── Application ─────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://mwazn:mwazn_secret@localhost:5432/mwazn_db

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_this_access_secret_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_MODE=log          # log | smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@mwazn.sa
SMTP_PASS=smtp_password
EMAIL_FROM=no-reply@mwazn.sa

# ─── Payment (Moyasar) — stub mode when empty ─────────────────────────────────
MOYASAR_SECRET_KEY=
MOYASAR_PUBLISHABLE_KEY=
MOYASAR_WEBHOOK_SECRET=

# ─── ZATCA e-invoicing — local XML generation when empty ─────────────────────
ZATCA_API_KEY=
ZATCA_API_URL=https://gw-fatoora.zatca.gov.sa/e-invoicing/developer-portal

# ─── Maroof CR validation — format-only check when empty ─────────────────────
MAROOF_API_KEY=

# ─── Seed credentials (dev/demo only — change before seeding production) ──────
SEED_ADMIN_EMAIL=admin@mwazn.sa
SEED_ADMIN_PASSWORD=Admin@1234
SEED_SUP_PASSWORD=Supplier@1234
SEED_BUY_PASSWORD=Buyer@1234
