# ─── Application ─────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://mwazn:mwazn_secret@localhost:5432/mwazn_db

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_this_access_secret_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_MODE=log          # log | smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@mwazn.sa
SMTP_PASS=smtp_password
EMAIL_FROM=no-reply@mwazn.sa
